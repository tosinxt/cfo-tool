rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check that the requesting user has role === 'admin' in their own user doc
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection: admins can read any user doc; users can only read their own
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if false; // provisioned server-side only
    }

    // Engagements: only admins via server-side routes
    // Client SDK access is intentionally blocked — all reads/writes go through API routes
    // that use the Admin SDK, which bypasses these rules entirely.
    match /engagements/{engagementId} {
      allow read, write: if isAdmin();
    }

    // Engagement events (audit log): admins read-only; no client writes
    match /engagements/{engagementId}/events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
