# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (paste the full JSON of your service account key, minified to one line)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenRouter
OPENROUTER_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_ADDRESS=no-reply@yourdomain.com

# Admin notification recipients (comma-separated)
ADMIN_NOTIFICATION_EMAILS=brooks@yourdomain.com,cfo@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode — set both to "true" to bypass Stripe, auth, emails, and AI (UI dev only)
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false

# Sentry (optional — errors are captured only in production unless SENTRY_DEBUG=1)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
